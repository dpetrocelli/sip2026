        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (producto) (count_over_time({namespace=\"ml-scraper\"} |= \"JSON escrito\" [24h])) / sum by (producto) (count_over_time({namespace=\"ml-scraper\"} |= \"=== Producto\" [24h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "% éxito por producto (JSON escrito / Producto iniciado)",
